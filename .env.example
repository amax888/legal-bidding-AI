# Copy thành .env và điền nếu cần
# OPENAI_API_KEY=sk-...   # Tùy chọn: dùng GPT để trả lời chat hay hơn

# Vector store: mặc định dùng FAISS (không cần Visual C++ trên Windows)
# USE_FAISS=1
# Nếu muốn dùng ChromaDB: cài C++ Build Tools, pip install chromadb, đặt USE_FAISS=0

# Bảo vệ /api/ingest khi deploy VPS: đặt key bí mật, gọi kèm header X-API-Key
# INGEST_API_KEY=your-secret-key-here
